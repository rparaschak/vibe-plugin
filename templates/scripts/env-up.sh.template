#!/usr/bin/env bash
# vibe-template: templates/scripts/env-up.sh.template v2 | generated 2026-07-24 | edits below this marker are yours
#
# env-up — the ONE sanctioned command to bring the project environment up.
# Idempotent: safe to re-run when services are already up.
# Self-verifying: after starting services it polls each for readiness and exits
# non-zero with a NAMED failure if anything is not ready within the timeout.
set -euo pipefail
trap 'echo "env-up: FAILED — a start command exited non-zero (see output above)" >&2' ERR

# No infra/server for this project (e.g. a library or CLI)? Fill
# INFRA_UP_CMD / APP_UP_CMD / READINESS_CHECKS below with `:` (a no-op) —
# the script must still run and exit 0.

# READY_TIMEOUT — max seconds to wait for any one service to become ready.
# Discover: time a cold start of the slowest dependency locally; round up.
# e.g. 60
READY_TIMEOUT="{{READY_TIMEOUT}}"

# INFRA_UP_CMD — starts backing infra (db, queue, containers). MUST be
# idempotent. Discover: the compose file / Makefile target for dependencies.
# e.g. docker compose up -d      (or: make local-infra)
echo "env-up: starting infra…"
{{INFRA_UP_CMD}}

# APP_UP_CMD — starts the app/server in the background so this script can poll.
# WARNING: never a foreground launcher held under `wait` with a teardown trap —
# when the launching session is reaped, the trap kills the stack for every session.
# Discover: the local dev run target; prefer a start that DETACHES (its own
# session/process group via setsid, or the stack's own daemon mode) and returns
# once launched. An attached launcher only exits at teardown, so its exit must
# never be read as readiness — readiness is the wait_port/wait_http polls below.
# Any stop path must find the stack by ground truth (port → PID/PGID), not by
# which session started it.
# e.g. setsid make start >/tmp/app.log 2>&1 &      (or: make start >/tmp/app.log 2>&1 &)
echo "env-up: starting app…"
{{APP_UP_CMD}}

# wait_port HOST PORT NAME — poll a TCP port until it accepts a connection.
wait_port() {
  local host="$1" port="$2" name="$3" waited=0
  until (exec 3<>"/dev/tcp/$host/$port") 2>/dev/null; do
    if [ "$waited" -ge "$READY_TIMEOUT" ]; then
      echo "env-up: FAILED — $name not listening on $host:$port after ${READY_TIMEOUT}s" >&2
      exit 1
    fi
    sleep 1; waited=$((waited + 1))
  done
  echo "env-up: ready — $name ($host:$port)"
}

# wait_http URL NAME — poll an HTTP endpoint until it returns a success status.
wait_http() {
  local url="$1" name="$2" waited=0
  until curl -fsS -o /dev/null "$url"; do
    if [ "$waited" -ge "$READY_TIMEOUT" ]; then
      echo "env-up: FAILED — $name health check $url not green after ${READY_TIMEOUT}s" >&2
      exit 1
    fi
    sleep 1; waited=$((waited + 1))
  done
  echo "env-up: ready — $name ($url)"
}

# READINESS_CHECKS — one wait_port/wait_http call per service a test needs up.
# Discover: the ports/health URLs infra and the app listen on (compose port maps,
# app config, the frontend's API base URL). Name each so its failure is legible.
# These polls are the ONLY readiness signal — never process liveness or a start
# command exiting.
# e.g. wait_port 127.0.0.1 5432 postgres
#      wait_http http://127.0.0.1:8080/healthz api
{{READINESS_CHECKS}}

echo "env-up: environment ready."
